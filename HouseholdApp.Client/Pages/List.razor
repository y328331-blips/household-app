@page "/"
@rendermode InteractiveWebAssembly
@using HouseholdApp.Client.Models
@using HouseholdApp.Client.Services
@inject TransactionApiClient Api
@inject IJSRuntime JS

<PageTitle>家計簿</PageTitle>

<h1>家計簿</h1>

@if (loading)
{
    <p>読み込み中...</p>
}
else
{
    <div class="summary-cards">
        <div class="card income">
            <span class="card-label">収入</span>
            <span class="card-value">¥@totalIncome.ToString("N0")</span>
        </div>
        <div class="card expense">
            <span class="card-label">支出</span>
            <span class="card-value">¥@totalExpense.ToString("N0")</span>
        </div>
        <div class="card balance">
            <span class="card-label">残高</span>
            <span class="card-value">¥@balance.ToString("N0")</span>
        </div>
    </div>

    @if (categoryTotals.Count > 0)
    {
        <h2>支出の内訳</h2>
        <div class="stacked-bar">
            @foreach (var (category, amount) in categoryTotals)
            {
                <div class="stacked-bar-segment"
                     style="flex-grow:@amount.ToString(System.Globalization.CultureInfo.InvariantCulture);background:@GetCategoryColor(category)"
                     title="@category ¥@amount.ToString("N0")"></div>
            }
        </div>
        <div class="category-legend">
            @foreach (var (category, amount) in categoryTotals)
            {
                var percent = totalExpense == 0 ? 0 : Math.Round(amount * 100.0 / totalExpense);
                <div class="legend-row">
                    <span class="legend-swatch" style="background:@GetCategoryColor(category)"></span>
                    <span class="legend-label">@category</span>
                    <span class="legend-amount">¥@amount.ToString("N0")</span>
                    <span class="legend-percent">@percent%</span>
                </div>
            }
        </div>
    }

    <h2>記録一覧（日付順）</h2>
    @if (transactions.Count == 0)
    {
        <p>まだ記録がありません。<a href="/input">最初の記録を入力する</a></p>
    }
    else
    {
        <table class="transaction-table">
            <thead>
                <tr>
                    <th>日付</th>
                    <th>項目</th>
                    <th>種別</th>
                    <th class="amount-col">金額</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var t in transactions)
                {
                    <tr>
                        <td>@t.Date.ToString("yyyy/MM/dd")</td>
                        <td>@t.Category</td>
                        <td>
                            <span class="type-tag @(t.Type == TransactionType.Income ? "income" : "expense")">
                                @(t.Type == TransactionType.Income ? "収入" : "支出")
                            </span>
                        </td>
                        <td class="amount-col">¥@t.Amount.ToString("N0")</td>
                        <td class="delete-col">
                            <a class="edit-link" href="@($"/input/{t.Id}")" title="編集">編集</a>
                            <button type="button" class="delete-button" title="削除" @onclick="() => DeleteAsync(t)">削除</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
}

<a class="fab" href="/input" title="記録を追加">＋</a>

@code {
    // Fixed category → color mapping, so a category's color stays stable
    // regardless of its amount ranking. Unrecognized categories fall back
    // to a neutral "other" swatch rather than a generated hue.
    private static readonly Dictionary<string, string> CategoryColors = new()
    {
        ["日用品"] = "var(--cat-1)",
        ["食費"] = "var(--cat-2)",
        ["交通費"] = "var(--cat-3)",
        ["交際費"] = "var(--cat-4)",
    };

    private static string GetCategoryColor(string category) =>
        CategoryColors.GetValueOrDefault(category, "var(--cat-other)");

    private List<TransactionItem> transactions = [];
    private bool loading = true;
    private int totalIncome;
    private int totalExpense;
    private int balance;
    private List<(string Category, int Amount)> categoryTotals = [];

    protected override async Task OnInitializedAsync()
    {
        transactions = await Api.GetAllAsync();
        Recalculate();
        loading = false;
    }

    private async Task DeleteAsync(TransactionItem transaction)
    {
        var confirmed = await JS.InvokeAsync<bool>("confirm", $"{transaction.Date:yyyy/MM/dd} {transaction.Category} ¥{transaction.Amount:N0} を削除しますか？");
        if (!confirmed)
        {
            return;
        }

        await Api.DeleteAsync(transaction.Id);
        transactions.Remove(transaction);
        Recalculate();
    }

    private void Recalculate()
    {
        totalIncome = transactions.Where(t => t.Type == TransactionType.Income).Sum(t => t.Amount);
        totalExpense = transactions.Where(t => t.Type == TransactionType.Expense).Sum(t => t.Amount);
        balance = totalIncome - totalExpense;

        categoryTotals = transactions
            .Where(t => t.Type == TransactionType.Expense)
            .GroupBy(t => t.Category)
            .Select(g => (Category: g.Key, Amount: g.Sum(t => t.Amount)))
            .OrderByDescending(g => g.Amount)
            .ToList();
    }
}
